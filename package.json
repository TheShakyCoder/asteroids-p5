{
  "private": true,
  "name": "asteroids",
  "version": "0.1.0",
  "description": "npm init template for bootstrapping an empty Colyseus project",
  "type": "module",
  "main": "build/index.js",
  "engines": {
    "node": ">= 20.9.0"
  },
  "scripts": {
    "start": "tsx watch src/index.ts",
    "loadtest": "tsx loadtest/example.ts --room my_room --numClients 2",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "tsc -p tsconfig.build.json",
    "clean": "rimraf build public",
    "test": "mocha -r tsx test/**.test.ts --exit --timeout 15000"  },
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/colyseus/create-colyseus/issues"
  },
  "homepage": "https://github.com/colyseus/create-colyseus#readme",
  "devDependencies": {
    "@colyseus/loadtest": "^0.17.7",
    "@colyseus/sdk": "^0.17.17",
    "@colyseus/testing": "^0.17.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.1",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/mocha": "^10.0.1",
    "@types/nodemailer": "^6.4.17",
    "mocha": "^11.7.5",
    "rimraf": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@colyseus/bun-websockets": "^0.17.7",
    "@colyseus/schema": "^4.0.0",
    "@colyseus/tools": "^0.17.0",
    "bcryptjs": "^2.4.3",
    "colyseus": "^0.17.6",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0",
    "nodemailer": "^6.9.14"
  }
}
